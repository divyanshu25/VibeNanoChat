      "updated": 1776185494268,
      "link": null,
      "locked": false,
      "text": "model.eval()\nfor task in core_tasks:\n  for example in task.data:\n    losses = forward_model(choices)\n    pred = argmin(losses)  # likelihood\n  acc = correct / total\n  centered = (acc−rand)/(1−rand)\ncore_score = mean(centered_results)\nlog to wandb  ·  model.train()",
      "fontSize": 10.5,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "model.eval()\nfor task in core_tasks:\n  for example in task.data:\n    losses = forward_model(choices)\n    pred = argmin(losses)  # likelihood\n  acc = correct / total\n  centered = (acc−rand)/(1−rand)\ncore_score = mean(centered_results)\nlog to wandb  ·  model.train()",
      "lineHeight": 1.6,
      "index": "b0d",
      "frameId": null,
      "autoResize": true
