      "updated": 1776185494268,
      "link": null,
      "locked": false,
      "text": "· Reads RANK / LOCAL_RANK / WORLD_SIZE env vars  →  detects multi-GPU vs single process\n· Multi-GPU: init_process_group(backend='nccl')  ·  set_device(LOCAL_RANK)  ·  master = (rank==0)\n· Single: auto-detect cuda → mps → cpu  ·  master = True\n· torch.manual_seed(42) + cuda.manual_seed(42)  →  reproducible init across all ranks\n· Dispatches: run_pretraining()  or  run_sft()  →  finally destroy_process_group()",
      "fontSize": 11.5,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "· Reads RANK / LOCAL_RANK / WORLD_SIZE env vars  →  detects multi-GPU vs single process\n· Multi-GPU: init_process_group(backend='nccl')  ·  set_device(LOCAL_RANK)  ·  master = (rank==0)\n· Single: auto-detect cuda → mps → cpu  ·  master = True\n· torch.manual_seed(42) + cuda.manual_seed(42)  →  reproducible init across all ranks\n· Dispatches: run_pretraining()  or  run_sft()  →  finally destroy_process_group()",
      "lineHeight": 1.6,
      "index": "a7",
      "frameId": null,
      "autoResize": true
