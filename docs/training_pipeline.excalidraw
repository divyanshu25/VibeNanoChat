      "updated": 1776185494268,
      "link": null,
      "locked": false,
      "text": "model.eval()  ·  reset dataloader\nfor batch in range(val_loss_steps):\n  _, loss = model(X, Y, loss_reduction='none')\n  accumulate_bpb(loss, valid_tokens)\nall_reduce(total_loss, SUM) across ranks\nval_loss = total_loss / total_valid_tokens\nbpb     = total_nats / (8 × total_bytes)\nmodel.train()  →  log to wandb",
      "fontSize": 10.5,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "model.eval()  ·  reset dataloader\nfor batch in range(val_loss_steps):\n  _, loss = model(X, Y, loss_reduction='none')\n  accumulate_bpb(loss, valid_tokens)\nall_reduce(total_loss, SUM) across ranks\nval_loss = total_loss / total_valid_tokens\nbpb     = total_nats / (8 × total_bytes)\nmodel.train()  →  log to wandb",
      "lineHeight": 1.6,
      "index": "b0R",
      "frameId": null,
      "autoResize": true
    },
