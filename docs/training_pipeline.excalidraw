      "updated": 1776185494268,
      "link": null,
      "locked": false,
      "text": "# PREFILL phase\nkv_cache = KVCache(config)\nprefill_prompt(model, tokens, kv_cache)\n# DECODE loop\nwhile len(out) < max_tokens:\n  logits = forward(next_tok, kv_cache)\n  if detect <|python|>:\n    result = use_calculator(expr)\n    inject result tokens\n  next = sample(logits, temp, top_k)\n  if next == EOS: break\nall_reduce(correct, total) → accuracy",
      "fontSize": 10.5,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "# PREFILL phase\nkv_cache = KVCache(config)\nprefill_prompt(model, tokens, kv_cache)\n# DECODE loop\nwhile len(out) < max_tokens:\n  logits = forward(next_tok, kv_cache)\n  if detect <|python|>:\n    result = use_calculator(expr)\n    inject result tokens\n  next = sample(logits, temp, top_k)\n  if next == EOS: break\nall_reduce(correct, total) → accuracy",
      "lineHeight": 1.6,
      "index": "b0m",
      "frameId": null,
      "autoResize": true
    },
